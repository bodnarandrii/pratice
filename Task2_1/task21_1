#include <iostream>
#include <fstream>
#include <string>
#include <iterator>

int main() 
{
    // Змінні для збереження імен файлів
    std::string name1;
    std::string name2;

    // Зчитуємо імена файлів з консолі
    std::cin >> name1 >> name2;

    // Відкриваємо файли: inFile для читання, outFile для запису
    std::ifstream inFile(name1);
    std::ofstream outFile(name2);

    // Описуємо ітератор out типу ostream_iterator для запису у файл.
    // "\n" означає, що кожне число буде з нового рядка.
    std::ostream_iterator<int> out(outFile, "\n");

    // Цикл for з параметром-ітератором in типу istream_iterator.
    // std::istream_iterator<int>() без аргументів означає кінець файлу.
    for (std::istream_iterator<int> in(inFile); in != std::istream_iterator<int>(); in++) 
    {
        // Перевіряємо, чи число ненульове
        if (*in != 0) 
        {
            // Виконуємо оператор out = *in для запису числа у файл
            out = *in; 
        }
    }

    return 0;
}